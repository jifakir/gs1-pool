# GS1 Datalink (ACC example)
DATALINK_BASE_URL=https://gs1nl-api-acc.gs1.nl/datalink
DATALINK_SUBSCRIPTION_KEY=

# Target market (numeric string, e.g. 528 for NL)
TARGET_MARKET_COUNTRY_CODE=528

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=foods
MONGODB_COLLECTION=products
MONGODB_SYNC_STATE_COLLECTION=gs1_datalink_sync_state
# Raw Datalink items XML as fast-xml-parser JSON (one document per row/tradeItem by default)
MONGODB_XMLTOJSON_COLLECTION=xmltojson
# Fallback directory if MongoDB insert fails or payload exceeds BSON size (relative to cwd)
XMLTOJSON_LOCAL_DIR=storage/xmltojson
# JSON readability for xmltojson only (trim strings; optional drop empty strings)
XMLTOJSON_CLEAN_TRIM_STRINGS=true
XMLTOJSON_CLEAN_DROP_EMPTY_STRINGS=false
# skip = ignore duplicate itemId; replace = overwrite existing
XMLTOJSON_DEDUPE_MODE=skip
XML_TO_JSON_SAVE=true
# Map + upsert into products collection (set true when product mapping is ready)
SAVE_PRODUCTS=false

# Existing user id in your app (24 hex chars)
ADDED_BY_OBJECT_ID=61210a3c6ea2a51938724bb4

# Operational
HTTP_TIMEOUT_MS=60000
POLL_MAX_MS=900000
POLL_BASE_DELAY_MS=2000
POLL_MAX_DELAY_MS=30000
DRY_RUN=false
LOG_LEVEL=info
USER_AGENT=gs1-pool/1.0.0

# Item XML detail logs (poll 200 + sync startItems 200): set true to log previews (default 16Ki chars). Overrides below when combined with explicit char cap.
LOG_DATALINK_ITEM_DETAILS=false
# Explicit max characters for item XML previews. If > 0, always used. If 0 and LOG_DATALINK_ITEM_DETAILS=true, uses built-in default size. Max 524288.
LOG_DATALINK_ITEMS_BODY_PREVIEW_CHARS=0

# Optional: ISO8601 bootstrap when no cursor exists (e.g. 2024-01-01T00:00:00.000Z)
INITIAL_UPDATED_SINCE=
